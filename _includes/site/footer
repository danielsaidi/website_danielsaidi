<footer class="site-footer paper">
  <hr />
  <data class="u-url" href="{{ "/" | relative_url }}"></data>
  <div class="wrapper">
    <div class="row">
      {%- assign pages = site.pages -%}
      {%- assign paths_site = site.footer_pages_sitemap -%}
      {%- assign paths_app = site.footer_pages_app -%}
      
      <div class="column">
        <p class="footer-toggle">Site</p>
        <div class="footer-content">
          {% include kankoda/site/footer-links paths=site.footer.sitemap %}
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">News</p>
        <div class="footer-content">
          <a href="{{site.urls.blog}}">Blog</a>
          <a href="{{site.urls.blog-archive}}">Blog Archive</a>
          <a href="{{site.urls.rss}}">RSS</a>
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">Social</p>
        <div class="footer-content">
          <a href="{{site.urls.email}}">E-mail</a>
          <a href="{{site.urls.bluesky}}">Bluesky</a>
          <a href="{{site.urls.mastodon}}">Mastodon</a>
          <a href="{{site.urls.linkedin}}">LinkedIn</a>
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">Music</p>
        <div class="footer-content">
          <a href="/music">Bands</a>
          <a href="/bands/daniel-saidi">Daniel Saidi</a>
          <a href="/bands/misfortune">Misfortune</a>
          <a href="/bands/sgt-black">sgt. Black</a>
          <a href="/bands/magnus-wakander">Wakander</a>
        </div>
      </div>

      <div class="column">
        <p class="footer-toggle">Businesses</p>
        <div class="footer-content">
          <a href="https://kankoda.com">Company</a>
          <a href="https://keyboardkit.com/app">KeyboardKit</a>
        </div>
      </div>
    </div>
    
    <div class="copyright">
      © {{site.copyright_year}} <a href="{{site.copyright_url}}">{{site.copyright_owner}}</a>. All rights reserved.
    </div>
  </div>
</footer>
